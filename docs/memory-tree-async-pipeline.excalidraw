    {
      "id": "t3",
      "type": "text",
      "x": 833,
      "y": 205,
      "width": 264,
      "height": 108,
      "text": "jobs::start(workspace_dir)\n\nrecover_stale_locks()\nspawn 3 worker tasks\nNotify wakeup + 5s polling fallback\nshared Semaphore(3) for LLM-bound work",
      "fontSize": 18,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
