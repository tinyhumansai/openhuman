{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "openhuman-overlay",
  "version": "0.1.0",
  "identifier": "com.openhuman.overlay",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1430",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "overlay",
        "title": "",
        "width": 376,
        "height": 432,
        "minWidth": 376,
        "minHeight": 432,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "visible": false,
        "center": false,
        "x": 16,
        "y": 16
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
