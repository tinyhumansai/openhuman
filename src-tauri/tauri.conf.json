{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AlphaHuman",
  "version": "0.1.0",
  "identifier": "com.alphahuman.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build:app",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AlphaHuman",
        "width": 800,
        "height": 720,
        "visible": false,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["../skills/skills"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": [
        "./libraries/libtdjson.1.8.29.dylib",
        "./libraries/libssl.3.dylib",
        "./libraries/libcrypto.3.dylib"
      ]
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["alphahuman"]
      }
    }
  }
}
